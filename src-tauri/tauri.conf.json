{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anvil",
  "version": "0.1.0",
  "identifier": "com.pjanderson.anvil",
  "build": {
    "beforeDevCommand": "node_modules/.bin/vite dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node_modules/.bin/vite build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Anvil",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-src 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENEQTNGQThCOEY5OEFEQTYKUldTbXJaaVBpL3FqemVYcEo1R1Nvb2tiMmgzc1BuZmFzRkVjZmhSVTVqclJzZ1RkbGw1Y2EzZ2kK",
      "endpoints": [
        "https://github.com/pjanderson/anvil/releases/latest/download/latest.json"
      ]
    }
  }
}
